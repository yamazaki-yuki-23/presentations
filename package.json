{
  "name": "presentations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "preview": "marp --theme-set ./templates/theme.css -s",
    "build:pdf": "bun ./scripts/export-slides.ts pdf",
    "build:pdf:all": "bun ./scripts/export-slides.ts pdf --all",
    "build:html": "bun ./scripts/export-slides.ts html",
    "build:html:all": "bun ./scripts/export-slides.ts html --all",
    "build:pptx": "marp --theme-set ./templates/theme.css -o dist/slides.pptx"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.2.3"
  }
}
